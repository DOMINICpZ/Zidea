{
  "name": "zidea",
  "version": "0.1.0",
  "description": "灵光宝盒 - 知识管理与学习平台",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "npm-run-all -p renderer:dev electron:dev",
    "build": "npm run renderer:build && npm run electron:compile && electron-builder",
    "renderer:dev": "cd electron/renderer && npm run dev",
    "renderer:build": "cd electron/renderer && npm run build",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:compile": "cd electron && tsc"
  },
  "build": {
    "appId": "com.zidea.app",
    "productName": "灵光宝盒",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "electronDownload": {
      "cache": "./electron-cache",
      "version": "41.3.0"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage", "deb"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "electron/dist/**/*",
      "!electron/dist/**/*.map",
      "electron/renderer/dist/**/*",
      "!electron/renderer/dist/**/*.map",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build",
        "filter": ["*.ico", "*.png"]
      }
    ]
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^24.9.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0"
  }
}
